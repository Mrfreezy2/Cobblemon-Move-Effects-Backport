{
    "format_version": "1.10.0",
    "particle_effect": {
        "description": {
            "identifier": "cobblemon:blizzard_shards",
            "basic_render_parameters": {
                "material": "particles_blend",
                "texture": "textures/particles/generic/ice/iceshard"
            }
        },
        "curves": {
            "variable.shardsize": {
                "type": "linear",
                "input": "v.particle_age",
                "horizontal_range": "v.particle_lifetime",
                "nodes": [0, 1, 1, 1, 1, 1, 0.5, 0]
            }
        },
        "components": {
            "minecraft:emitter_rate_steady": {
                "spawn_rate": "6*math.clamp(v.entity_height*0.9,1,2)",
                "max_particles": 30
            },
            "minecraft:emitter_lifetime_once": { "active_time": 0.5 },
            "minecraft:emitter_initialization": {
                "creation_expression": "v.target_deltaz=(v.target_deltaz!=0.0)?v.target_deltaz:5.0;v.target_deltax=0;v.target_deltay=0;v.target_distance=5;"
            },
            "minecraft:emitter_shape_point": {
                "direction": ["-v.target_deltax", "v.target_deltay", "-v.target_deltaz"],
                "offset": [
                    "math.sin(v.emitter_age*600)*0.9",
                    "math.random(-0.2, 0.6)",
                    "math.cos(v.emitter_age*600)*0.9"
                ]
            },
            "minecraft:particle_initial_spin": { "rotation": "math.random_integer(0,3)*90" },
            "minecraft:particle_initial_speed": 10,
            "minecraft:particle_motion_dynamic": {
                "linear_acceleration": [0, 0, 0],
                "linear_drag_coefficient": 0
            },
            "minecraft:particle_lifetime_expression": { "max_lifetime": 1.5 },
            "minecraft:particle_appearance_billboard": {
                "size": ["0.28*v.shardsize", "0.28*v.shardsize"],
                "facing_camera_mode": "rotate_xyz",
                "uv": {
                    "texture_width": 42,
                    "texture_height": 14,
                    "flipbook": {
                        "base_UV": [0, 0],
                        "size_UV": [14, 14],
                        "step_UV": [14, 0],
                        "frames_per_second": 6,
                        "max_frame": 2,
                        "loop": true
                    }
                }
            },
            "minecraft:particle_appearance_tinting": {
                "color": {
                    "interpolant": "v.particle_age / v.particle_lifetime",
                    "gradient": {
                        "0.0": "#FFFFFFFF",
                        "0.3": "#AADFFFFF",
                        "0.6": "#88CCFFFF",
                        "0.85": "#4499CCCC",
                        "1.0": "#FFFFFF44"
                    }
                }
            }
        }
    }
}