{
    "timeline": [
        { "type": "add_holds", "holds": ["effects"] },
        { "type": "animation", "animation": ["present", "special"], "delay": 1.25 },
        { "type": "entity_particles", "effect": "cobblemon:present_actor", "locator": "special_attack", "entityCondition": "q.entity.is_user == true" },
        { "type": "entity_molang", "entityCondition": "q.entity.is_user == true", "expressions": ["q.sound('move.present.actor');"] },
        { "type": "pause", "pause": 0.6 },
        { "type": "entity_molang", "entityCondition": "q.entity.is_user == false && q.missed(q.entity.uuid) == false", "expressions": ["q.sound('move.present.target');"] },
        { "type": "remove_holds", "holds": ["effects"] },
        { "type": "pause", "pause": 1.8 }
    ]
}
